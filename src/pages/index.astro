---
import Layout from '~/layouts/Layout.astro';
import SalonScene from '~/components/salon/SalonScene.astro';

const metadata = {
  title: 'Joanails - Salon de manucure à Cherbourg | Onglerie, Gel & Nail Art',
  description:
    'Joanails, salon de manucure à Cherbourg-en-Cotentin : pose de gel, vernis semi-permanent, nail art, soins des mains et pieds. Réservez votre moment beauté !',
  image: '/images/logo.png',
  canonical: 'https://joanails.fr/',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <div id="intro" class="intro-wrap">
    <video
      id="intro-video"
      autoplay
      muted
      playsinline
      class="intro-video"
    >
      <source src="/videos/banner.mp4" type="video/mp4" />
    </video>
    <div class="intro-overlay" aria-hidden="true"></div>
    <div class="intro-logo">
      <img src="/images/logo.png" alt="Joanails" class="intro-logo-img" />
    </div>
  </div>

  <div id="salon-wrap" class="salon-wrap hidden-initially">
    <SalonScene />
  </div>
</Layout>

<script>
  function initIntro() {
    const intro = document.getElementById('intro') as HTMLElement | null;
    const video = document.getElementById('intro-video') as HTMLVideoElement | null;
    const salonWrap = document.getElementById('salon-wrap') as HTMLElement | null;
    if (!intro || !video || !salonWrap) return;

    function revealSalon() {
      if (!intro || !salonWrap) return;
      intro.classList.add('fade-out');
      salonWrap.classList.remove('hidden-initially');
      salonWrap.classList.add('fade-in');
      setTimeout(() => intro.remove(), 800);
    }

    video.playbackRate = 2;
    const fallback = setTimeout(revealSalon, 2800);

    video.addEventListener('ended', () => {
      clearTimeout(fallback);
      revealSalon();
    });

    video.addEventListener('error', () => {
      clearTimeout(fallback);
      revealSalon();
    });
  }

  document.addEventListener('astro:page-load', initIntro);
  initIntro();
</script>

<style is:global>
  body {
    background: #e8d8c4;
    overflow: hidden;
    margin: 0;
  }
</style>

<style>
  .intro-wrap {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: #1a0f0a;
    transition: opacity 0.8s ease;
  }
  .intro-wrap.fade-out {
    opacity: 0;
    pointer-events: none;
  }
  .intro-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .intro-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 15, 10, 0.35);
  }
  .intro-logo {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .intro-logo-img {
    width: min(260px, 55vw);
    filter: invert(1) sepia(1) saturate(2) hue-rotate(280deg);
    animation: logo-breathe 3s ease-in-out infinite;
  }
  @keyframes logo-breathe {
    0%, 100% { opacity: 0.85; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.04); }
  }
  .salon-wrap {
    width: 100vw;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
  }
  .hidden-initially {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .fade-in {
    opacity: 1 !important;
  }
</style>
