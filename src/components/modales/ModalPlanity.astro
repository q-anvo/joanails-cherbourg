<style>
  .reserver-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .reserver-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: rgb(91, 75, 64);
    color: white;
    font-family: var(--aw-font-heading);
    font-size: clamp(0.95rem, 3vw, 1.05rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    padding: 1rem 1.5rem;
    border-radius: 16px;
    transition: opacity 0.2s, transform 0.15s;
    text-align: center;
  }
  .reserver-cta:hover { opacity: 0.88; transform: translateY(-2px); }

  .cta-sub {
    text-align: center;
    font-size: 0.875rem;
    color: rgba(91, 75, 64, 0.7);
    margin: -0.5rem 0 0;
    line-height: 1.5;
  }

  .reserver-separator {
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(91, 75, 64, 0.45);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    position: relative;
  }
  .reserver-separator::before,
  .reserver-separator::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 38%;
    height: 1px;
    background: rgba(140, 95, 60, 0.2);
  }
  .reserver-separator::before { left: 0; }
  .reserver-separator::after { right: 0; }

  .reserver-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .option-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(231, 193, 155, 0.2);
    border: 1px solid rgba(140, 95, 60, 0.2);
    border-radius: 14px;
    padding: 1rem 1.125rem;
    text-decoration: none;
    transition: background 0.18s, transform 0.15s;
  }
  .option-card:hover {
    background: rgba(231, 193, 155, 0.38);
    transform: translateX(4px);
  }

  .option-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(140, 95, 60, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgb(140, 95, 60);
    flex-shrink: 0;
  }

  .option-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .option-title {
    font-family: var(--aw-font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: rgb(80, 48, 28);
  }
  .option-detail {
    font-size: 0.875rem;
    color: rgb(140, 95, 60);
  }

  .horaires-block {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgb(91, 75, 64);
    background: rgba(231, 193, 155, 0.2);
    border-radius: 10px;
    padding: 0.625rem 0.875rem;
  }
</style>
