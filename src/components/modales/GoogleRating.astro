---
import ratingData from '~/assets/google_rating.json';

const { rating, reviewCount, url } = ratingData as {
  rating: number;
  reviewCount: number;
  url: string;
};

const fullStars = Math.floor(rating);
const hasHalf = rating - fullStars >= 0.3 && rating - fullStars < 0.8;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
---

<div class="gr-widget">
  <div class="gr-header">
    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    <span class="gr-label">Avis Google</span>
  </div>

  <div class="gr-body">
    <span class="gr-score">{rating.toFixed(1)}</span>
    <div class="gr-stars" aria-label={`${rating} étoiles sur 5`}>
      {Array.from({ length: fullStars }).map(() => (
        <svg class="gr-star gr-star-full" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
      {hasHalf && (
        <svg class="gr-star gr-star-half" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <defs>
            <linearGradient id="half-grad" x1="0" x2="1" y1="0" y2="0">
              <stop offset="50%" stop-color="currentColor"/>
              <stop offset="50%" stop-color="transparent"/>
            </linearGradient>
          </defs>
          <path fill="url(#half-grad)" stroke="currentColor" stroke-width="1" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      )}
      {Array.from({ length: emptyStars }).map(() => (
        <svg class="gr-star gr-star-empty" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.5" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
    <span class="gr-count">{reviewCount} avis</span>
  </div>

  <a href={url} target="_blank" rel="noopener" class="gr-link">
    Voir tous les avis
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12" aria-hidden="true">
      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
      <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
    </svg>
  </a>
</div>

<style>
  .gr-widget {
    background: rgba(255,252,245,.75);
    border: 1px solid rgba(140,95,60,.1);
    border-radius: 14px;
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .gr-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .gr-label {
    font-family: var(--aw-font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    color: rgb(80,48,28);
  }
  .gr-body {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .gr-score {
    font-family: var(--aw-font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    color: rgb(80,48,28);
    line-height: 1;
  }
  .gr-stars {
    display: flex;
    align-items: center;
    gap: 1px;
    color: #f5a623;
  }
  .gr-star-empty { color: rgba(140,95,60,.3); }
  .gr-count {
    font-size: 0.8rem;
    color: rgb(120,85,55);
    margin-left: 0.125rem;
  }
  .gr-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgb(66,133,244);
    text-decoration: none;
    width: fit-content;
    transition: color 0.15s;
  }
  .gr-link:hover { color: rgb(40,100,200); text-decoration: underline; }
</style>
