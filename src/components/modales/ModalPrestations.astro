---
import { PRESTATIONS } from '~/data/prestations';
import almasImg from '~/assets/images/almas.png';
import theBaseImg from '~/assets/images/the-base.png';
import albiImg from '~/assets/images/albi.png';
---

<div class="prestations-wrap">

  <div class="prestations-grid">
    {PRESTATIONS.map((cat) => (
      <div class="prestation-cat">
        <h3 class="cat-title">{cat.categorie}</h3>
        <ul class="prestation-list">
          {cat.items.map((item) => (
            <li class="prestation-item">
              <span class="item-nom">{item.nom}</span>
              <span class="item-prix">{item.prix}</span>
              {item.detail && <span class="item-detail">{item.detail}</span>}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="videos-section">
    <div class="videos-grid">
      <div class="video-item">
        <video src="/videos/pose_gel.mp4" poster="/images/logo.png" muted loop playsinline class="prestation-video" title="Pose de gel"></video>
        <span class="video-label">Pose de gel</span>
      </div>
      <div class="video-item">
        <video src="/videos/pose_nail_art.mp4" poster="/images/logo.png" muted loop playsinline class="prestation-video" title="Nail art"></video>
        <span class="video-label">Nail art</span>
      </div>
      <div class="video-item">
        <video src="/videos/nettoyage_cuticules.mp4" poster="/images/nail-art-cherbourg-3.png" muted loop playsinline class="prestation-video" title="Soin des ongles"></video>
        <span class="video-label">Soin des ongles</span>
      </div>
    </div>
  </div>

  <div class="marques-section">
    <h3 class="marques-title">Marques utilisées</h3>
    <div class="marques-logos">
      <img src={almasImg.src} alt="Almas" class="marque-logo" />
      <img src={theBaseImg.src} alt="The Base" class="marque-logo" />
      <img src={albiImg.src} alt="Albi" class="marque-logo" />
    </div>
  </div>

</div>

<script>
  document.querySelectorAll<HTMLVideoElement>('.prestation-video').forEach((v) => {
    v.addEventListener('click', () => { v.paused ? v.play() : v.pause(); });
    v.play().catch(() => {});
  });
</script>

<style>
  .prestations-wrap { display: flex; flex-direction: column; gap: 1.5rem; }

  .section-title {
    font-family: var(--aw-font-heading);
    color: rgb(140, 95, 60);
    font-size: 1rem;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(140, 95, 60, 0.2);
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem;
  }
  .video-item {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .prestation-video {
    width: 100%;
    aspect-ratio: 9/16;
    object-fit: cover;
    border-radius: 12px;
    background: #1a0f0a;
    cursor: pointer;
  }
  .video-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgb(91, 75, 64);
    text-align: center;
    font-family: var(--aw-font-heading);
  }

  .prestations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .prestation-cat {
    background: rgba(231, 193, 155, 0.25);
    border-radius: 16px;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  .cat-title {
    font-family: var(--aw-font-heading);
    color: rgb(140, 95, 60);
    font-size: 1rem;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(140, 95, 60, 0.2);
  }
  .prestation-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prestation-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .item-nom { font-size: 0.875rem; color: rgb(91, 75, 64); }
  .item-prix { font-weight: 600; color: rgb(140, 95, 60); font-size: 0.875rem; }
  .item-detail { font-size: 0.75rem; color: rgba(91, 75, 64, 0.6); width: 100%; }

  .marques-section {}
  .marques-title {
    font-family: var(--aw-font-heading);
    color: rgb(140, 95, 60);
    font-size: 1rem;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(140, 95, 60, 0.2);
  }
  .marques-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem;
    padding: 1rem 0;
  }
  .marque-logo {
    height: 64px;
    width: auto;
    max-width: 130px;
    object-fit: contain;
    filter: grayscale(0.2);
  }
</style>
