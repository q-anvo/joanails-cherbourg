---
import GoogleRating from './GoogleRating.astro';
---

<div class="contact-content">

  <div class="map-wrap">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2616.2!2d-1.6255!3d49.6378!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x480c90db9f1f1f1f%3A0x1!2s73+Rue+du+Val+de+Saire%2C+50100+Cherbourg-en-Cotentin!5e0!3m2!1sfr!2sfr!4v1700000000000!5m2!1sfr!2sfr"
      width="100%"
      height="280"
      style="border:0; border-radius: 14px;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Localisation Joanails Cherbourg"
    ></iframe>
  </div>

  <div class="contact-info">
    <ul class="contact-list">
      <li>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="rgb(140,95,60)" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <span>73 rue du Val de Saire, Cherbourg-en-Cotentin</span>
      </li>
      <li>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="rgb(140,95,60)" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 12a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1.22h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.91a16 16 0 006.18 6.18l1.26-1.26a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <a href="tel:+33749394404">07 49 39 44 04</a>
      </li>
      <li>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="rgb(140,95,60)" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>Lun–Ven 9h–18h &nbsp;·&nbsp; Sam 9h–17h</span>
      </li>
    </ul>
  </div>

  <GoogleRating />

</div>

<style>
  .contact-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .map-wrap { border-radius: 14px; overflow: hidden; }
  .contact-info {
    background: rgba(231, 193, 155, 0.2);
    border-radius: 14px;
    padding: 0.875rem 1rem;
  }
  .contact-list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgb(91, 75, 64);
  }
  .contact-list a { color: rgb(91, 75, 64); text-decoration: none; }
  .contact-list a:hover { color: rgb(140, 95, 60); }
</style>
