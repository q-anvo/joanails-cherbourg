---
import SalonModal from './SalonModal.astro';
import ModalPrestations from '../modales/ModalPrestations.astro';
import ModalSalon from '../modales/ModalSalon.astro';
import ModalInstagram from '../modales/ModalInstagram.astro';
import ModalPlanity from '../modales/ModalPlanity.astro';
import ModalContact from '../modales/ModalContact.astro';
import ModalFAQ from '../modales/ModalFAQ.astro';
import ModalMentions from '../modales/ModalMentions.astro';
import ModalPrivacy from '../modales/ModalPrivacy.astro';
---

<section class="salon-scene" aria-label="Joanails — Salon de manucure">

  <!-- ── Left panel : image + logo + desktop nav ── -->
  <div class="panel-image">
    <div class="scene-bg lofi-grain lofi-vignette">
      <img src="/images/salon_bg.jpg" alt="Intérieur du salon Joanails"
        class="scene-img lofi-img" width="1440" height="1920" />
      <div class="lofi-warm-overlay" aria-hidden="true"></div>
      <div class="lofi-scanlines" aria-hidden="true"></div>
      <div class="lamp-glow-el" aria-hidden="true"></div>
      <div class="lamp-glow-el lamp-glow-2" aria-hidden="true"></div>
    </div>
    <div class="scene-title">
      <img src="/images/logo.png" alt="Logo Joanails" class="title-logo" />
      <p class="title-tagline">Profitez d'un moment de détente dans un cocon proche du centre ville de Cherbourg.</p>
    </div>

    <!-- Desktop 4-button nav -->
    <div class="desktop-nav">
      <button class="desktop-nav-btn" data-desktop-btn="salon" aria-label="Salon">
        <div class="desktop-nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <span class="desktop-nav-label">Salon</span>
      </button>
      <button class="desktop-nav-btn" data-desktop-btn="prestations" aria-label="Prestations">
        <div class="desktop-nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20" aria-hidden="true">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
          </svg>
        </div>
        <span class="desktop-nav-label">Prestations</span>
      </button>
      <button class="desktop-nav-btn" data-desktop-btn="planity" aria-label="Réserver">
        <div class="desktop-nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <circle cx="8" cy="15" r="1" fill="currentColor"/>
            <circle cx="12" cy="15" r="1" fill="currentColor"/>
          </svg>
        </div>
        <span class="desktop-nav-label">Réserver</span>
      </button>
      <button class="desktop-nav-btn" data-desktop-btn="instagram" aria-label="Instagram">
        <div class="desktop-nav-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <span class="desktop-nav-label">Instagram</span>
      </button>
    </div>
  </div>

  <!-- ── Right panel : content ── -->
  <div class="panel-content">

    <!-- MOBILE : floating pill (salon, prestations, réserver, insta) -->
    <div class="scene-footer">
      <button class="icon-btn" data-modal-target="salon" aria-label="Le salon">
        <div class="icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="24" height="24" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <span class="icon-label">salon</span>
      </button>

      <button class="icon-btn" data-modal-target="prestations" aria-label="Prestations">
        <div class="icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="24" height="24" aria-hidden="true">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
          </svg>
        </div>
        <span class="icon-label">prestations</span>
      </button>

      <button class="icon-btn" data-modal-target="planity" aria-label="Réserver">
        <div class="icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="24" height="24" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <circle cx="8" cy="15" r="1" fill="currentColor"/>
            <circle cx="12" cy="15" r="1" fill="currentColor"/>
          </svg>
        </div>
        <span class="icon-label">réserver</span>
      </button>

      <button class="icon-btn" data-modal-target="instagram" aria-label="Instagram">
        <div class="icon-wrap">
          <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <span class="icon-label">insta</span>
      </button>
    </div>

    <!-- MOBILE : footer discret -->
    <div class="site-footer-mobile">
      <button class="footer-link" data-modal-target="mentions">Mentions légales</button>
      <span class="footer-sep">·</span>
      <button class="footer-link" data-modal-target="privacy">Confidentialité</button>
      <span class="footer-sep">·</span>
      <a class="footer-link" href="https://q-anvo.github.io/" target="_blank" rel="noopener">Made with love by Q.A</a>
      <span class="footer-sep">·</span>
      <span class="footer-copy">© Tous droits réservés</span>
    </div>

    <!-- DESKTOP : panneau droit (scroll continu) -->
    <div class="dp-wrapper">
      <div class="dp-content" id="dp-scroll">

        <!-- ── Welcome ── -->
        <div class="dp-welcome" id="dp-welcome">
          <div class="dp-welcome-inner">
            <p class="dp-welcome-eyebrow">Salon de manucure · Cherbourg</p>
            <h2 class="dp-welcome-title">Bienvenue chez <em>Joanails</em></h2>
            <p class="dp-welcome-desc">Poses en gel, nail art, soins des ongles — dans un cocon chaleureux à deux pas du centre-ville.</p>
            <a
              href="https://www.fresha.com/fr/a/joanails-cherbourg-cherbourg-en-cotentin-cherbourg-en-cotentin-73-rue-du-val-de-saire-wk17zc9v"
              target="_blank" rel="noopener"
              class="dp-welcome-cta"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
                <circle cx="8" cy="15" r="1" fill="currentColor"/>
                <circle cx="12" cy="15" r="1" fill="currentColor"/>
              </svg>
              Réserver sur Fresha
            </a>
          </div>
          <div class="dp-welcome-flowers" aria-hidden="true">
            <img src="/images/flower-right.png" alt="" class="dp-welcome-flower dp-welcome-flower-a" />
            <img src="/images/flower-left.png"  alt="" class="dp-welcome-flower dp-welcome-flower-b" />
          </div>
        </div>

        <!-- ── Salon ── -->
        <div class="dp-section" id="dp-salon"><ModalSalon /></div>

        <!-- ── Spacer 1 ── -->
        <div class="dp-spacer" aria-hidden="true">
          <img src="/images/spacer.jpg" class="dp-spacer-img" alt="" loading="lazy" />
          <div class="dp-spacer-overlay"></div>
        </div>

        <!-- ── Prestations ── -->
        <div class="dp-section" id="dp-prestations">
          <ModalPrestations />
          <hr class="section-divider" />
          <ModalFAQ />
        </div>

        <!-- ── Spacer 2 ── -->
        <div class="dp-spacer" aria-hidden="true">
          <img src="/images/spacer2.jpg" class="dp-spacer-img" alt="" loading="lazy" />
          <div class="dp-spacer-overlay"></div>
        </div>

        <!-- ── Réserver + Contact ── -->
        <div class="dp-section" id="dp-planity">
          <ModalPlanity />
          <hr class="section-divider" />
          <ModalContact />
        </div>

        <!-- ── Spacer 3 ── -->
        <div class="dp-spacer" aria-hidden="true">
          <img src="/images/spacer3.jpg" class="dp-spacer-img" alt="" loading="lazy" />
        </div>

        <!-- ── Instagram ── -->
        <div class="dp-section" id="dp-instagram"><ModalInstagram instanceId="desktop" /></div>

        <!-- ── Footer (fin du scroll) ── -->
        <div class="dp-footer">
          <button class="footer-link dp-footer-link" data-modal-target="mentions">Mentions légales</button>
          <span class="footer-sep dp-footer-sep">·</span>
          <button class="footer-link dp-footer-link" data-modal-target="privacy">Confidentialité</button>
          <span class="footer-sep dp-footer-sep">·</span>
          <a class="footer-link dp-footer-link" href="https://q-anvo.github.io/" target="_blank" rel="noopener">Made with love by Q.A</a>
          <span class="footer-sep dp-footer-sep">·</span>
          <span class="footer-copy dp-footer-copy">© Tous droits réservés</span>
        </div>

      </div>
    </div>

  </div>

  <!-- Mobile modals -->
  <SalonModal id="planity" title="Prendre Rendez-vous">
    <ModalPlanity />
    <hr class="section-divider" />
    <ModalContact />
  </SalonModal>
  <SalonModal id="instagram" title="Instagram"><ModalInstagram instanceId="mobile" /></SalonModal>
  <SalonModal id="salon"     title="Le Salon"><ModalSalon /></SalonModal>
  <SalonModal id="prestations" title="Prestations & Tarifs">
    <ModalPrestations />
    <hr class="section-divider" />
    <ModalFAQ />
  </SalonModal>
  <SalonModal id="mentions"  title="Mentions légales"><ModalMentions /></SalonModal>
  <SalonModal id="privacy"   title="Confidentialité"><ModalPrivacy /></SalonModal>

</section>

<script>
  function initScene() {
    const DESKTOP_BP = 1024;
    const isDesktop = () => window.innerWidth >= DESKTOP_BP;

    /* ── grwapi: floating badge always hidden, inline reviews shown ── */
    let grwapiLoaded = false;
    function ensureGrwapi() {
      if (grwapiLoaded) return;
      grwapiLoaded = true;
      if (document.querySelector('script[src*="grwapi"]')) return;
      const s = document.createElement('script');
      s.src = 'https://grwapi.net/widget.min.js';
      s.async = true;
      document.head.appendChild(s);
    }
    const grwHide = document.createElement('style');
    grwHide.textContent = '[class*="grw-net-widget"],[class*="grw-widget-four"]{display:none!important;pointer-events:none!important;visibility:hidden!important}';
    document.head.appendChild(grwHide);

    /* ── Desktop: scroll-based navigation ── */
    const scrollEl = document.getElementById('dp-scroll');
    if (scrollEl) {
      // Scroll to section on button click
      document.querySelectorAll<HTMLButtonElement>('.desktop-nav-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.desktopBtn;
          if (!id) return;
          const target = document.getElementById('dp-' + id);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      // Activate nav button as sections enter the viewport
      const sections = scrollEl.querySelectorAll<HTMLElement>('.dp-section[id]');
      const sectionObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const sectionId = entry.target.id.replace('dp-', '');
          document.querySelectorAll<HTMLElement>('.desktop-nav-btn').forEach((btn) => {
            btn.classList.toggle('active', btn.dataset.desktopBtn === sectionId);
          });
        });
      }, { root: scrollEl, threshold: 0.3 });
      sections.forEach((s) => sectionObs.observe(s));

      // Deactivate all buttons when scrolled back to welcome
      const welcomeEl = document.getElementById('dp-welcome');
      if (welcomeEl) {
        const welcomeObs = new IntersectionObserver((entries) => {
          if (entries[0]?.isIntersecting) {
            document.querySelectorAll<HTMLElement>('.desktop-nav-btn').forEach((b) => b.classList.remove('active'));
          }
        }, { root: scrollEl, threshold: 0.4 });
        welcomeObs.observe(welcomeEl);
      }

      // Lazy-load grwapi when planity section enters view
      const planityEl = document.getElementById('dp-planity');
      if (planityEl) {
        const grwObs = new IntersectionObserver((entries) => {
          if (entries.some((e) => e.isIntersecting)) { ensureGrwapi(); grwObs.disconnect(); }
        }, { root: scrollEl, threshold: 0.1 });
        grwObs.observe(planityEl);
      }
    }

    /* ── Mobile: modals ── */
    function openModal(id: string) {
      const overlay = document.querySelector<HTMLElement>(`.modal-overlay[data-modal-id="${id}"]`);
      if (!overlay) return;
      if (id === 'planity') ensureGrwapi();
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      (overlay.querySelector('[data-modal-close]') as HTMLElement | null)?.focus();
    }
    function closeModal(overlay: HTMLElement) {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    /* ── data-modal-target: desktop scrolls, mobile opens modal ── */
    document.querySelectorAll<HTMLButtonElement>('[data-modal-target]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.modalTarget;
        if (!id) return;
        if (isDesktop() && ['salon', 'prestations', 'planity', 'instagram'].includes(id)) {
          const target = document.getElementById('dp-' + id);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          openModal(id);
        }
      });
    });

    /* ── Modal backdrop + close button ── */
    document.querySelectorAll<HTMLElement>('.modal-overlay').forEach((overlay) => {
      overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(overlay); });
      overlay.querySelector('[data-modal-close]')?.addEventListener('click', () => closeModal(overlay));
    });

    /* ── Escape ── */
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll<HTMLElement>('.modal-overlay.open').forEach(closeModal);
    });
  }

  let _sceneReady = false;
  function safeInitScene() {
    if (_sceneReady) return;
    _sceneReady = true;
    initScene();
  }
  document.addEventListener('astro:page-load', safeInitScene);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', safeInitScene);
  } else {
    safeInitScene();
  }
</script>

<style>
  /* ── Scene ── */
  .salon-scene {
    position: relative;
    width: 100vw; height: 100vh; height: 100svh;
    overflow: hidden;
  }

  /* ── MOBILE: image fullscreen ── */
  .panel-image { position: absolute; inset: 0; }

  .scene-bg { position: absolute; inset: 0; background: #1a1008; }
  .scene-img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }

  .lofi-warm-overlay {
    position: absolute; inset: 0;
    background: rgba(240,200,130,.06);
    pointer-events: none; z-index: 1;
  }
  .lofi-scanlines {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(to bottom,transparent,transparent 3px,rgba(0,0,0,.03) 3px,rgba(0,0,0,.03) 4px);
    pointer-events: none; z-index: 2;
  }
  .lamp-glow-el {
    position: absolute; top: 35%; left: 12%;
    width: 180px; height: 180px; border-radius: 50%;
    background: radial-gradient(circle,rgba(255,220,120,.3) 0%,transparent 70%);
    pointer-events: none; z-index: 2;
    animation: lamp-glow 4s ease-in-out infinite;
  }
  .lamp-glow-2 { top: 6%; left: 35%; width: 120px; height: 120px; background: radial-gradient(circle,rgba(255,210,130,.2) 0%,transparent 70%); animation-delay: 2s; }
  @keyframes lamp-glow { 0%,100%{opacity:.8} 50%{opacity:1} }

  /* ── Logo + tagline overlay ── */
  .scene-title {
    position: absolute; top: 22%; left: 50%;
    transform: translate(-50%,-50%);
    display: flex; flex-direction: column; align-items: center;
    gap: 14px; text-align: center; z-index: 3;
    animation: title-appear 1.2s ease both;
    width: 88%; max-width: 340px;
  }
  @keyframes title-appear {
    from { opacity: 0; transform: translate(-50%, calc(-50% - 14px)); }
    to   { opacity: 1; transform: translate(-50%,-50%); }
  }

  .title-logo {
    width: clamp(180px, 62vw, 280px); height: auto;
    filter:
      invert(1) sepia(.6) saturate(2) hue-rotate(300deg) brightness(1.5)
      drop-shadow(0 0 8px rgba(255,200,210,.9))
      drop-shadow(0 0 18px rgba(220,140,150,.65))
      drop-shadow(0 2px 4px rgba(30,10,5,.6));
    animation: logo-breathe 4s ease-in-out infinite;
  }
  @keyframes logo-breathe { 0%,100%{opacity:.92;transform:scale(1)} 50%{opacity:1;transform:scale(1.03)} }

  .title-tagline {
    font-family: var(--aw-font-sans);
    font-size: clamp(1.1rem, 4.5vw, 1.3rem);
    font-weight: 500; line-height: 1.5;
    color: rgba(255,245,225,.93);
    text-shadow: 0 1px 12px rgba(10,5,0,.85), 0 2px 6px rgba(0,0,0,.6);
    text-align: center; width: 100%; margin: 0;
    animation: tagline-appear 1.2s ease .25s both;
  }
  @keyframes tagline-appear {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Desktop nav hidden on mobile */
  .desktop-nav { display: none; }

  /* ── MOBILE: content overlay ── */
  .panel-content { position: absolute; inset: 0; pointer-events: none; }
  .dp-wrapper { display: none; }

  /* ── Mobile pill ── */
  .scene-footer {
    position: absolute;
    bottom: clamp(36px, 7svh, 56px);
    left: 50%; transform: translateX(-50%);
    pointer-events: auto;
    display: flex; align-items: center;
    gap: clamp(4px,1.5vw,10px);
    background: rgba(255,246,232,.72);
    backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255,218,168,.5);
    border-radius: 28px;
    padding: clamp(8px,2vw,12px) clamp(10px,2.5vw,16px);
    box-shadow: 0 6px 32px rgba(30,10,5,.22), 0 1px 0 rgba(255,255,255,.4) inset;
    white-space: nowrap;
  }

  .icon-btn {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    background: none; border: none; cursor: pointer; padding: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .icon-wrap {
    width: clamp(48px,12.5vw,58px); height: clamp(48px,12.5vw,58px);
    border-radius: 14px;
    background: rgba(255,250,242,.55);
    border: 1px solid rgba(255,215,160,.4);
    display: flex; align-items: center; justify-content: center;
    color: rgb(140,95,60);
    transition: background .18s, transform .18s, box-shadow .18s, color .18s;
  }
  .icon-btn:hover .icon-wrap, .icon-btn:focus-visible .icon-wrap {
    background: rgba(255,238,218,.92);
    transform: scale(1.1) translateY(-2px);
    box-shadow: 0 6px 18px rgba(140,95,60,.3);
    color: rgb(91,55,25);
